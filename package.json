{
  "name": "remember-me",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "test-workflow": "ng test --configuration ci",
    "codegen": "graphql-codegen --config codegen.ts",
    "e2e": "playwright test",
    "cloud": "ng serve --configuration cloud",
    "prod": "ng serve --configuration production",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@apollo/client": "^4.0.7",
    "@ngrx/signals": "^21.1.0",
    "@vitest/browser-playwright": "^4.1.4",
    "apollo-angular": "^13.0.0",
    "firebase": "^12.12.0",
    "graphql": "^16.11.0",
    "ngx-editor": "^19.0.0-beta.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.0.1",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.1",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/graphql": "^14.2.3",
    "@types/node": "^25.0.3",
    "angular-eslint": "21.3.1",
    "baseline-browser-mapping": "^2.9.19",
    "daisyui": "^5.2.3",
    "eslint": "^10.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1"
  }
