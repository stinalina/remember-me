{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "remember-me": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/remember-me",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "loader": {
              ".txt": "text"
            },
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },
            "cloud": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.cloud.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "headers": {
              "Content-Security-Policy": "default-src 'self'; script-src 'self' https://storage.ko-fi.com 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://storage.ko-fi.com https://cdn.ko-fi.com; img-src 'self' data: https:; connect-src 'self' http://localhost:8081 http://localhost:7072 https://hasura.orangemeadow-efd57554.germanywestcentral.azurecontainerapps.io https://fa-rememberme-backend-cchucab0bsdpepb5.germanywestcentral-01.azurewebsites.net https://identitytoolkit.googleapis.com https://securetoken.googleapis.com; frame-src https://ko-fi.com https://storage.ko-fi.com; font-src 'self' data: https://fonts.gstatic.com; object-src 'none'"
            }
          },
          "configurations": {
            "production": {
              "buildTarget": "remember-me:build:production"
            },
            "development": {
              "buildTarget": "remember-me:build:development"
            },
            "cloud": {
              "buildTarget": "remember-me:build:cloud"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "karmaConfig": "karma.conf.js"
          }
        }
      }
    }
  }
}
